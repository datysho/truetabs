{
  "manifest_version": 3,
  "name": "TrueTabs",
  "description": "__MSG_appDesc__",
  "default_locale": "en",
  "version": "1.8.0",
  "minimum_chrome_version": "121",
  "key": "",
  "homepage_url": "https://github.com/datysho/truetabs",
  "permissions": [
    "tabs",
    "tabGroups",
    "storage",
    "alarms",
    "notifications",
    "favicon",
    "webNavigation"
  ],
  "optional_host_permissions": [
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.x.ai/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/tt-16.png",
      "32": "icons/tt-32.png",
      "48": "icons/tt-48.png",
      "128": "icons/tt-128.png"
    },
    "default_title": "TrueTabs",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/tt-16.png",
    "32": "icons/tt-32.png",
    "48": "icons/tt-48.png",
    "128": "icons/tt-128.png"
  }
}
